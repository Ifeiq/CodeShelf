---
import Layout from '@/layouts/Layout.astro';
import Hero from '@/components/Hero';
import Todo from '@/components/Todo';
import CTA from '@/components/CTA';
import TopHeaders from '@/components/TopHeaders';
import Headers from '@/components/Headers';
import Plans from '@/components/Plans';
import Bands from '@/components/Bands';
import AboutUs from '@/components/AboutUs';
---

<Layout>
	<Hero 
	title="Construa interfaces perfeitas",
	subtitle="Com código pronto para usar",
	description="De tabelas de preços complexas a layouts essenciais — pegue o código que você precisa e foque no que importa: entregar valor para seus clientes"
	client:only="react" 
	/>

	<TopHeaders client:only="react" />
	<Headers client:only="react" />
	<Plans client:only="react" />
	<Bands client:only="react" />
	<AboutUs client:only="react" />
	<CTA client:only="react" />
    <Todo client:only="react" />
</Layout>
