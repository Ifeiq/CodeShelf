---
import Layout from "@/layouts/Layout.astro";
import DynamicCodes from "@/components/DynamicCodes";
import TesteComponent from "@/components/Teste";
export const prerender = false;
import { Icon } from "@iconify/react";

const TOP_HEADERS_API_URL = "https://code-shelf-backend.vercel.app//api/top-headers";

let data: { docs: { code: string }[] } = { docs: [] };
try {
  const response = await fetch(TOP_HEADERS_API_URL);
  if (response.ok) {
    data = await response.json();
  }
} catch {
  data = { docs: [] };
}
---

<Layout>
    <div class="flex flex-col">
        {
            data.docs.map((item: { code: string }, index: number) => (
                <div data-index={index}>
                    <DynamicCodes code={item.code} client:only="react" />
                </div>
            ))
        }
        <TesteComponent client:only="react" />
    </div>
</Layout>
