---
import Layout from "@/layouts/Layout.astro";
import DynamicCodes from "@/components/DynamicCodes";
export const prerender = false;

const TOP_HEADERS_API_URL =
  import.meta.env.PUBLIC_TOP_HEADERS_API_URL ?? "http://localhost:3000/api/top-headers";

let data: { docs: { code: string }[] } = { docs: [] };
try {
  const response = await fetch(TOP_HEADERS_API_URL);
  if (response.ok) {
    data = await response.json();
  }
} catch {
  data = { docs: [] };
}
---

<Layout>
    <div class="flex flex-col">
        <h1>Teste</h1>
        {
            data.docs.map((item: { code: string }, index: number) => (
                <div data-index={index}>
                    <DynamicCodes code={item.code} client:only="react" />
                </div>
            ))
        }
        <!-- <TesteComponent client:only="react" /> -->
    </div>
</Layout>
